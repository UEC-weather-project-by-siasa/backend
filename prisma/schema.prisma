// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum AlertType {
  USER      // user สร้างเอง
  SYSTEM    // admin สร้าง แจ้งเฉพาะ device
  GLOBAL    // admin แจ้งทุกคน
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  profilePicture String   @default("/profilePicture.png") 
  password       String
  role           Role     @default(USER) 
  tokenVersion   Int      @default(0)

  devices        Device[]
  alertRules     AlertRule[]
  notifications  Notification[]
  
  createdAt      DateTime @default(now())
}

model Device {
  id          Int      @id @default(autoincrement())
  deviceId    String   @unique
  deviceKey   String

  name        String?
  model       String?
  firmware    String?

  owner       User?    @relation(fields: [ownerId], references: [id])
  ownerId     Int?

  isOnline    Boolean  @default(false)
  lastSeen    DateTime @updatedAt

  latitude    Float?
  longitude   Float?

  sensors     DeviceSensor[]
  logs        DeviceLog[]   // 👈 เพิ่มตรงนี้
  alertRules  AlertRule[]
  alertLogs   AlertLog[]

  createdAt   DateTime @default(now())

  @@index([deviceId])
}

model Sensor {
  id        Int    @id @default(autoincrement())
  name      String @unique  // temperature, humidity
  unit      String // °C, %, hPa

  model     String? // เช่น DHT22, BMP280
  brand     String? // เช่น Bosch

  devices   DeviceSensor[]
  alertRules     AlertRule[]
}

model DeviceSensor {
  id        Int     @id @default(autoincrement())

  device    Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId  Int

  sensor    Sensor  @relation(fields: [sensorId], references: [id])
  sensorId  Int

  @@unique([deviceId, sensorId])
}

model DeviceLog {
  id          Int      @id @default(autoincrement())
  
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId    Int
  
  // เพิ่มตัวนี้เพื่อแบ่งหมวดหมู่ Log ให้ชัดเจน
  level       LogLevel
  eventCode   String?  // เช่น "CONN_ERR", "BATT_LOW", "SENSOR_OFFLINE"
  
  message     String
  
  isRead      Boolean  @default(false)

  // เก็บข้อมูลสภาพแวดล้อมตอนเกิดเหตุ (เช่น { "rssi": -65, "vcc": 3.3 })
  meta        Json?

  createdAt   DateTime @default(now())

  @@index([deviceId])
  @@index([createdAt])
  @@index([level]) 
}

model AlertRule {
  id          Int      @id @default(autoincrement())

  // 👇 เพิ่มใหม่
  name        String
  note        String?
  type        AlertType @default(USER)

  // USER Alert จะมี userId
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int?

  // GLOBAL Alert อาจไม่ต้องมี device
  device      Device?   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId    Int?

  sensor      Sensor?   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  sensorId    Int?

  condition   String
  threshold   Float

  isActive    Boolean  @default(true)
  lastTrigger DateTime?

  createdBy   Int?     // admin ที่สร้าง
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  alertLogs   AlertLog[]

  @@index([deviceId])
  @@index([userId])
  @@index([type])
}


model AlertLog {
  id          Int       @id @default(autoincrement())
  
  alertRule   AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId      Int

  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId    Int

  sensorName  String    // เผื่อไว้แสดงผลเร็วๆ โดยไม่ต้อง join
  condition   String
  threshold   Float
  actualValue Float
  message     String    // ข้อความอธิบายเช่น "High Temp Warning: temperature triggered: 36 > 35"
  isRead      Boolean   @default(false) // เผื่อทำระบบ Mark as read ในหน้าเว็บ

  createdAt   DateTime  @default(now())

  @@index([ruleId])
  @@index([deviceId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  type      String   @default("ALERT") // ALERT, SYSTEM, etc.
  isRead    Boolean  @default(false)
  
  // เชื่อมโยงกับ AlertLog เผื่ออยากกดไปดูรายละเอียด
  alertLogId Int?
  
  createdAt DateTime @default(now())

  @@index([userId])
}